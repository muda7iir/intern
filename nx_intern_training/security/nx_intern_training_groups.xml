<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Module Category -->
    <record id="module_category_nx_intern_training" model="ir.module.category">
        <field name="name">NerithonX Internship</field>
        <field name="sequence">200</field>
    </record>

    <!-- Define the Privilege -->
    <record id="privilege_intern_training" model="res.groups.privilege">
        <field name="name">Internship Training</field>
        <field name="category_id" ref="module_category_nx_intern_training"/>
    </record>

    <!-- Intern Group -->
    <record id="group_intern_training_intern" model="res.groups">
        <field name="name">Intern</field>
        <field name="privilege_id" ref="privilege_intern_training"/>
    </record>

    <!-- Manager Group -->
    <record id="group_intern_training_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="privilege_id" ref="privilege_intern_training"/>
        <field name="implied_ids" eval="[(4, ref('group_intern_training_intern'))]"/>
    </record>

    <!-- Admin Group -->
    <record id="group_intern_training_admin" model="res.groups">
        <field name="name">Admin</field>
        <field name="privilege_id" ref="privilege_intern_training"/>
        <field name="implied_ids" eval="[(4, ref('group_intern_training_manager'))]"/>
    </record>

    <!-- Auto-assign Administrator users to the Admin Group -->
    <record id="base.user_admin" model="res.users">
        <field name="groups_id" eval="[(4, ref('group_intern_training_admin'))]"/>
    </record>
    <record id="base.user_root" model="res.users">
        <field name="groups_id" eval="[(4, ref('group_intern_training_admin'))]"/>
    </record>
</odoo>
