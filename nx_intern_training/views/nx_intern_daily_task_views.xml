<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="nx_intern_daily_task_view_list" model="ir.ui.view">
        <field name="name">nx.intern.daily.task.list</field>
        <field name="model">nx.intern.daily.task</field>
        <field name="arch" type="xml">
            <list decoration-muted="state == 'locked'" decoration-success="state == 'approved'" decoration-danger="state == 'rejected'">
                <field name="day_number"/>
                <field name="title"/>
                <field name="enrollment_id"/>
                <field name="intern_user_id" widget="many2one_avatar_user"/>
                <field name="deadline"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'pending'"
                       decoration-success="state == 'approved'"
                       decoration-warning="state in ('submitted', 'revision_required')"
                       decoration-danger="state == 'rejected'"
                       decoration-muted="state == 'locked'"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="nx_intern_daily_task_view_form" model="ir.ui.view">
        <field name="name">nx.intern.daily.task.form</field>
        <field name="model">nx.intern.daily.task</field>
        <field name="arch" type="xml">
            <form string="Daily Task">
                <header>
                    <field name="state" widget="statusbar"
                           statusbar_visible="pending,submitted,approved"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(nx_intern_training.nx_intern_submission_action)d"
                                type="action"
                                class="oe_stat_button"
                                icon="fa-upload"
                                context="{'search_default_task_id': id, 'default_task_id': id}">
                            <field name="submission_count" widget="statinfo" string="Submissions"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="title"/>
                        <h1>
                            <field name="title" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Task Info">
                            <field name="enrollment_id"/>
                            <field name="program_id"/>
                            <field name="day_number"/>
                            <field name="deadline"/>
                        </group>
                        <group string="People">
                            <field name="intern_user_id" widget="many2one_avatar_user"/>
                            <field name="manager_id" widget="many2one_avatar_user"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Instructions" name="instructions">
                            <field name="instructions" readonly="1"/>
                        </page>
                        <page string="Deliverables" name="deliverables">
                            <field name="deliverables" readonly="1"/>
                        </page>
                        <page string="Submissions" name="submissions">
                            <field name="submission_ids">
                                <list>
                                    <field name="intern_user_id"/>
                                    <field name="state" widget="badge"
                                           decoration-info="state == 'submitted'"
                                           decoration-success="state == 'approved'"
                                           decoration-warning="state == 'revision_required'"
                                           decoration-danger="state == 'rejected'"/>
                                    <field name="score"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="nx_intern_daily_task_view_kanban" model="ir.ui.view">
        <field name="name">nx.intern.daily.task.kanban</field>
        <field name="model">nx.intern.daily.task</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="title"/>
                <field name="day_number"/>
                <field name="intern_user_id"/>
                <field name="state"/>
                <field name="deadline"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_content">
                            <strong>Day <field name="day_number"/>: <field name="title"/></strong>
                            <div class="text-muted">
                                <field name="intern_user_id" widget="many2one_avatar_user"/>
                            </div>
                            <div class="text-muted" t-if="record.deadline.raw_value">
                                Deadline: <field name="deadline"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Search View -->
    <record id="nx_intern_daily_task_view_search" model="ir.ui.view">
        <field name="name">nx.intern.daily.task.search</field>
        <field name="model">nx.intern.daily.task</field>
        <field name="arch" type="xml">
            <search string="Search Tasks">
                <field name="title"/>
                <field name="intern_user_id"/>
                <field name="enrollment_id"/>
                <field name="program_id"/>
                <filter string="My Tasks" name="filter_my_tasks"
                        domain="[('intern_user_id', '=', uid)]"/>
                <separator/>
                <filter string="Pending" name="filter_pending" domain="[('state', '=', 'pending')]"/>
                <filter string="Submitted" name="filter_submitted" domain="[('state', '=', 'submitted')]"/>
                <filter string="Approved" name="filter_approved" domain="[('state', '=', 'approved')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="State" name="groupby_state" context="{'group_by': 'state'}"/>
                    <filter string="Intern" name="groupby_intern" context="{'group_by': 'intern_user_id'}"/>
                    <filter string="Program" name="groupby_program" context="{'group_by': 'program_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action: All Daily Tasks -->
    <record id="nx_intern_daily_task_action" model="ir.actions.act_window">
        <field name="name">Daily Tasks</field>
        <field name="res_model">nx.intern.daily.task</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="search_view_id" ref="nx_intern_daily_task_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No daily tasks found.
            </p>
            <p>Tasks are auto-generated when an internship is started.</p>
        </field>
    </record>

    <!-- Action: My Dashboard (current user tasks, kanban default) -->
    <record id="nx_intern_daily_task_my_dashboard_action" model="ir.actions.act_window">
        <field name="name">My Dashboard</field>
        <field name="res_model">nx.intern.daily.task</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="nx_intern_daily_task_view_search"/>
        <field name="context">{'search_default_filter_my_tasks': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No tasks assigned to you yet.
            </p>
            <p>Your daily training tasks will appear here once your internship starts.</p>
        </field>
    </record>
</odoo>
