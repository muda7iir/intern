<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View -->
    <record id="nx_intern_mbti_wizard_view_form" model="ir.ui.view">
        <field name="name">nx.intern.mbti.wizard.form</field>
        <field name="model">nx.intern.mbti.wizard</field>
        <field name="arch" type="xml">
            <form string="MBTI Personality Onboarding">
                <sheet>
                    <div class="text-center mb-4">
                        <h2 style="color: #875A7B;">Welcome to NerithonX Technologies!</h2>
                        <p class="text-muted">
                            To personalize your internship track and roles, please complete your MBTI Personality Assessment.
                        </p>
                    </div>
                    <group>
                        <group>
                            <field name="user_id" readonly="1" options="{'no_open': True}"/>
                            <field name="mbti_type" placeholder="e.g., INTJ, ENFP, INFJ" style="text-transform: uppercase; font-size: 1.5rem; text-align: center; font-weight: bold; letter-spacing: 3px;"/>
                        </group>
                    </group>
                    
                    <!-- Quick Reference Guide in the Wizard itself -->
                    <div class="card bg-light mt-3">
                        <div class="card-body">
                            <h5 class="card-title text-info"><i class="fa fa-info-circle"></i> MBTI Quick Reference Guide</h5>
                            <div class="row">
                                <div class="col-md-3">
                                    <strong>1. Energy Style</strong><br/>
                                    <span class="text-muted">Introvert (I) vs Extrovert (E)</span>
                                </div>
                                <div class="col-md-3">
                                    <strong>2. Thinking Style</strong><br/>
                                    <span class="text-muted">Sensing (S) vs Intuition (N)</span>
                                </div>
                                <div class="col-md-3">
                                    <strong>3. Decision Style</strong><br/>
                                    <span class="text-muted">Thinking (T) vs Feeling (F)</span>
                                </div>
                                <div class="col-md-3">
                                    <strong>4. Structure Style</strong><br/>
                                    <span class="text-muted">Judging (J) vs Perceiving (P)</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </sheet>
                <footer>
                    <button name="action_submit" string="Submit Assessment" type="object" class="oe_highlight"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action to open Wizard -->
    <record id="nx_intern_mbti_wizard_action" model="ir.actions.act_window">
        <field name="name">MBTI Onboarding</field>
        <field name="res_model">nx.intern.mbti.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
