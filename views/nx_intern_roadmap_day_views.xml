<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="nx_intern_roadmap_day_view_list" model="ir.ui.view">
        <field name="name">nx.intern.roadmap.day.list</field>
        <field name="model">nx.intern.roadmap.day</field>
        <field name="arch" type="xml">
            <list>
                <field name="program_id"/>
                <field name="day_number"/>
                <field name="title"/>
                <field name="estimated_hours"/>
                <field name="difficulty"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="nx_intern_roadmap_day_view_form" model="ir.ui.view">
        <field name="name">nx.intern.roadmap.day.form</field>
        <field name="model">nx.intern.roadmap.day</field>
        <field name="arch" type="xml">
            <form string="Roadmap Day">
                <sheet>
                    <div class="oe_title">
                        <label for="title"/>
                        <h1>
                            <field name="title" placeholder="Day Title"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="program_id"/>
                            <field name="day_number"/>
                            <field name="estimated_hours"/>
                        </group>
                        <group>
                            <field name="difficulty"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Learning Objectives" name="objectives">
                            <field name="learning_objectives"/>
                        </page>
                        <page string="Instructions" name="instructions">
                            <field name="instructions"/>
                        </page>
                        <page string="Deliverables" name="deliverables">
                            <field name="deliverables"/>
                        </page>
                        <page string="Attachments" name="attachments">
                            <field name="attachment_ids" widget="many2many_binary"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="nx_intern_roadmap_day_action" model="ir.actions.act_window">
        <field name="name">Roadmap Days</field>
        <field name="res_model">nx.intern.roadmap.day</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No roadmap days found.
            </p>
        </field>
    </record>
</odoo>
